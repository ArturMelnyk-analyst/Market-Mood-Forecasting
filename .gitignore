# ✅ Keep only final cleaned data & .gitkeep in /data
/data/*
!/data/.gitkeep
!/data/cleaned_data.csv

# ✅ Keep only final model and .gitkeep in /models
/models/*
!/models/.gitkeep
!/models/xgb_market_mood.pkl

# ✅ Gradio user-generated SHAP plots
images/explain/shap_waterfall_user.png

# ✅ Ignore virtual environments and secrets
venv/
.env
.env.*

# ✅ Ignore Jupyter checkpoints & notebooks' temporary files
.ipynb_checkpoints/
*.ipynb~

# ✅ Ignore Python bytecode and caches
__pycache__/
*.py[cod]
*.so

# ✅ Ignore VSCode or other editor folders 
.vscode/
.idea/

# ✅ Ignore system files
.DS_Store
Thumbs.db

# ✅ Ignore OS logs, test/experiment files
*.log
*.tmp
*.bak