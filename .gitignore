# ================================
# Data
# ================================
# Keep only cleaned and raw subfolders + .gitkeep
!/data/.gitkeep
!/data/cleaned/**
!/data/raw/**
/data/feature_engineered/**

# ================================
# Models
# ================================
# Keep all committed artifacts in /models
!/models/**
# Still keep .gitkeep
!/models/.gitkeep

# ================================
# Virtual envs and secrets
# ================================
venv/
.env
.env.*
.venv/
*.env

# ================================
# Jupyter checkpoints & temp files
# ================================
.ipynb_checkpoints/
*.ipynb~

# ================================
# Python bytecode and caches
# ================================
__pycache__/
*.py[cod]
*.so

# ================================
# Editors
# ================================
.vscode/
.idea/

# ================================
# System files
# ================================
.DS_Store
Thumbs.db

# ================================
# Logs & temp
# ================================
*.log
*.tmp
*.bak

# ================================
# Hugging Face configs
# ================================
/.huggingface/*
!.huggingface/config_template.json

# ================================
# Hugging Face autogenerated
# ================================
.gitattributes
space.yaml
