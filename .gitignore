# 📦 Ignore everything else in /data except cleaned_data.csv and .gitkeep
/data/*
!/data/.gitkeep
!data/cleaned_data.csv

# Ignore model files except .gitkeep and xgb_market_mood.pkl
/models/*
!/models/.gitkeep
!/models/xgb_market_mood.pkl


# Ignore virtual environment and environment secrets
venv/
.env

# Ignore Jupyter checkpoints
.ipynb_checkpoints/

# Ignore Python cache
__pycache__/
*.py[cod]

# Ignore system files
.DS_Store
Thumbs.db
